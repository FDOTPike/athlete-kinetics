{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "target": "es2020",
    "lib": ["es2020"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@ak/core-db": ["../../packages/core-db/src/index.ts"],
      "@ak/inference": ["../../packages/inference/src/index.ts"]
    }
  },
  "include": [
    "src",
    "../../packages/core-db/src",
    "../../packages/inference/src"
  ]
}
